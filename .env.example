# --- server ---
NODE_ENV=development
PORT=4000
# Comma-separated origins allowed to call the API with credentials
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# --- database ---
# In dev the Nest app talks to PgBouncer; PgBouncer talks to postgres
DATABASE_URL=postgres://pai:pai_dev@localhost:6432/prescription_ai
# Direct connection (bypasses PgBouncer) — used only by node-pg-migrate
DATABASE_DIRECT_URL=postgres://pai:pai_dev@localhost:5434/prescription_ai

# --- redis ---
REDIS_URL=redis://localhost:6380

# --- auth ---
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- integrations (leave blank in dev until wired) ---
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWD=
SSLCOMMERZ_SANDBOX=true

SMS_PROVIDER=
SMS_API_KEY=

RESEND_API_KEY=

S3_REGION=ap-south-1
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

SENTRY_DSN=
